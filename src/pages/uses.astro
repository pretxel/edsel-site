---
import { render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import SEOHead from "../components/SEOHead.astro";
import { getPage } from "../lib/content";
import { t } from "../lib/i18n";

const lang = "es" as const;
const entry = await getPage("uses", lang);
const title = entry?.data.title ?? t("page.uses.title", {}, lang);
const description =
  entry?.data.description ?? t("page.uses.description", {}, lang);
const updated = entry?.data.updated;

const Content = entry ? (await render(entry)).Content : null;

const alternateLanguages = [
  { lang: "es" as const, url: "/uses" },
  { lang: "en" as const, url: "/en/uses" },
];
---

<PageLayout
  title={`${title} | Edsel Serrano`}
  eyebrow={t("nav.uses", {}, lang)}
  description={description}
  updated={updated}
  lang={lang}
  currentPath={Astro.url.pathname}
>
  <SEOHead
    slot="head"
    title={`${title} | Edsel Serrano`}
    description={description}
    canonical="/uses"
    language={lang}
    alternateLanguages={alternateLanguages}
    type="website"
  />
  {Content ? <Content /> : <p>{t("page.uses.description", {}, lang)}</p>}
</PageLayout>
