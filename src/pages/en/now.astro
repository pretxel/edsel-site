---
import { render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import SEOHead from "../../components/SEOHead.astro";
import { getPage } from "../../lib/content";
import { t } from "../../lib/i18n";

const lang = "en" as const;
const entry = await getPage("now", lang);
const title = entry?.data.title ?? t("page.now.title", {}, lang);
const description =
  entry?.data.description ?? t("page.now.description", {}, lang);
const updated = entry?.data.updated;

const Content = entry ? (await render(entry)).Content : null;

const alternateLanguages = [
  { lang: "es" as const, url: "/now" },
  { lang: "en" as const, url: "/en/now" },
];

const placeholder = t("page.now.description", {}, lang);
---

<PageLayout
  title={`${title} | Edsel Serrano`}
  eyebrow={t("nav.now", {}, lang)}
  description={description}
  updated={updated}
  lang={lang}
  currentPath={Astro.url.pathname}
>
  <SEOHead
    slot="head"
    title={`${title} | Edsel Serrano`}
    description={description}
    canonical="/en/now"
    language={lang}
    alternateLanguages={alternateLanguages}
    type="website"
  />
  {Content ? <Content /> : <p>{placeholder}</p>}
</PageLayout>
