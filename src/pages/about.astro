---
import { render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import SEOHead from "../components/SEOHead.astro";
import { getPage } from "../lib/content";
import { t } from "../lib/i18n";

const lang = "es" as const;
const entry = await getPage("about", lang);
const title = entry?.data.title ?? t("page.about.title", {}, lang);
const description =
  entry?.data.description ?? t("page.about.description", {}, lang);
const updated = entry?.data.updated;

const Content = entry ? (await render(entry)).Content : null;

const alternateLanguages = [
  { lang: "es" as const, url: "/about" },
  { lang: "en" as const, url: "/en/about" },
];
---

<PageLayout
  title={`${title} | Edsel Serrano`}
  eyebrow={t("nav.about", {}, lang)}
  description={description}
  updated={updated}
  lang={lang}
  currentPath={Astro.url.pathname}
>
  <SEOHead
    slot="head"
    title={`${title} | Edsel Serrano`}
    description={description}
    canonical="/about"
    language={lang}
    alternateLanguages={alternateLanguages}
    type="profile"
  />
  {Content ? (
    <Content />
  ) : (
    <p>{t("page.about.description", {}, lang)}</p>
  )}
</PageLayout>
