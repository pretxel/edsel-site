---
import type { Language } from "../../lib/i18n";
import { t } from "../../lib/i18n";
import SparklingSphere from "../Particles/sparklingSphere";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

// Brand-locked palette — no more random color picks per page load.
// Matches the `--accent-*` tokens from agent 02-design-system.
const particleColors = [0x46b4ff, 0x6cc4ff, 0x88ccff];

const projectsHref = lang === "en" ? "/en/blog" : "/blog";
const postsHref = lang === "en" ? "/en/blog" : "/blog";
---

<section
  class="relative isolate overflow-hidden border-b border-border-default"
  aria-labelledby="hero-title"
>
  <!--
    Decorative sphere. Lives behind the hero copy at low opacity so it
    feels like depth, not the whole show. Hidden from assistive tech.

    Hydration policy:
      • `client:media="(min-width: 768px)"` → skip the ~525KB Three.js
        bundle entirely on phones (where it pushes LCP past 6s and tanks
        the mobile Lighthouse score), keep it on desktop where it's a nice
        visual flourish.
      • The gradient at the bottom of the section already gives the hero
        depth on mobile, so dropping the sphere doesn't break the design.
  -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 hidden opacity-40 md:block"
    aria-hidden="true"
  >
    <SparklingSphere
      particleColors={particleColors}
      totalParticles={600}
      mobileTotalParticles={300}
      client:media="(min-width: 768px)"
    />
  </div>

  <!-- Subtle gradient fade-to-bg at the bottom so the next section meets a
       calm surface instead of fighting the sphere's brightness. -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-b from-transparent to-bg"
    aria-hidden="true"
  >
  </div>

  <div
    class="mx-auto flex min-h-[80vh] max-w-6xl flex-col items-start justify-center px-6 py-24 sm:px-8 md:min-h-[88vh] md:py-32"
  >
    <p
      class="font-mono text-xs uppercase tracking-[0.18em] text-accent"
    >
      {t("home.hero.eyebrow", {}, lang)}
    </p>

    <h1
      id="hero-title"
      class="mt-4 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-fg-strong sm:text-5xl md:text-6xl"
    >
      {t("home.hero.title", {}, lang)}
    </h1>

    <p
      class="mt-6 max-w-2xl text-lg leading-relaxed text-fg-muted sm:text-xl"
    >
      {t("home.hero.subtitle", {}, lang)}
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-3">
      <a
        href={projectsHref}
        class="inline-flex items-center justify-center rounded-md bg-accent px-5 py-3 text-sm font-semibold text-bg shadow-sm transition-colors duration-200 hover:bg-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {t("home.hero.cta.projects", {}, lang)}
        <span aria-hidden="true" class="ml-2">&rarr;</span>
      </a>

      <a
        href={postsHref}
        class="inline-flex items-center justify-center rounded-md border border-border-strong px-5 py-3 text-sm font-semibold text-fg-strong transition-colors duration-200 hover:bg-muted focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {t("home.hero.cta.posts", {}, lang)}
      </a>
    </div>
  </div>
</section>
