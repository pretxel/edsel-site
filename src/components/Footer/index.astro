---
import Social from "../Social/index.astro";
import { defaultLanguage, t, type Language } from "../../lib/i18n";

interface Props {
  lang?: Language;
}

const { lang = defaultLanguage } = Astro.props;
const prefix = lang === "en" ? "/en" : "";
---

<div class="footer">
  <nav class="footer-links" aria-label="Site links">
    <a href={`${prefix}/now`}>{t("nav.now", {}, lang)}</a>
    <a href={`${prefix}/uses`}>{t("nav.uses", {}, lang)}</a>
  </nav>
  <Social />
</div>

<style>
  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .footer-links a {
    color: var(--fg-muted);
    transition: color var(--dur-base) var(--ease-out);
  }

  .footer-links a:hover,
  .footer-links a:focus {
    color: var(--accent);
  }
</style>
