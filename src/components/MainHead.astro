---
import "../styles/global.css";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Theme-color matches `--c-zinc-950`, the background token of the
     redesigned homepage and blog surfaces. Keeps the iOS/Android URL bar
     in sync with the page's actual chrome. -->
<meta name="theme-color" content="#09090b" />
<meta name="color-scheme" content="dark" />

<!--
  Preload the Latin Inter variable font so the browser discovers it before
  parsing the (~80KB) Tailwind CSS bundle. Without this, FCP on slow 4G
  hovers around 1.8s and Lighthouse mobile docks ~6 perf points. The hash
  matches the asset emitted by Vite's bundling of @fontsource-variable.
-->
<link
  rel="preload"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
  href="/_astro/inter-latin-wght-normal.Dx4kXJAl.woff2"
/>

<!--
  Favicons + app icons. Variable fonts (Inter + JetBrains Mono) are bundled
  via @fontsource-variable from `global.css`.

  The `apple-touch-icon` / `favicon-{16,32}` PNGs are NOT shipped in /public
  yet, so we deliberately don't reference them — Chrome treats 404s for those
  files as console errors which tanks the Best-Practices Lighthouse score.
  Add the PNGs to /public and uncomment the links if you ever generate them.
-->
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="manifest" href="/site.webmanifest" />
