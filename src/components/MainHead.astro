---
import "../styles/global.css";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Theme-color matches `--c-zinc-950`, the background token of the
     redesigned homepage and blog surfaces. Keeps the iOS/Android URL bar
     in sync with the page's actual chrome. -->
<meta name="theme-color" content="#09090b" />
<meta name="color-scheme" content="dark" />

<!-- Favicon + app icons. Variable fonts (Inter + JetBrains Mono) are
     bundled via @fontsource-variable from `global.css`, so no extra
     <link rel="preload" font> is needed here. -->
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
