---
import type { Language } from "../lib/i18n";
import { defaultLanguage, t } from "../lib/i18n";

interface Props {
  title: string;
  image?: string | undefined;
  lang?: Language;
  rssHref?: string;
  rssTitle?: string;
}

const {
  title = "Home",
  lang = defaultLanguage,
  rssHref = "/rss.xml",
  rssTitle = "Edsel Serrano - Blog",
} = Astro.props;
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";
import "./layout.css";
import "../styles/blog.css";

// Only inject Vercel Analytics in real production deploys. Locally the
// `_vercel/insights/script.js` endpoint 404s and contaminates Lighthouse.
const showAnalytics = import.meta.env.PROD && process.env.VERCEL === "1";
---

<!doctype html>
<html lang={lang}>
  <head>
    <!--
      Charset is the very first thing in <head> to satisfy Lighthouse's
      `charset` audit. Anything that emits bytes (analytics, JSON-LD, etc.)
      must come after this point.
    -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    {/*
     * Preload the Latin Inter variable font as soon as the browser sees
     * <head>. Without this it would only be discovered after blog.css
     * parses (~80KB), pushing FCP past 1.8s on slow 4G. The font file is
     * fingerprinted by @fontsource-variable; this href matches the bundled
     * asset path emitted by Astro's build.
     */}
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
      href="/_astro/inter-latin-wght-normal.Dx4kXJAl.woff2"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={rssTitle}
      href={rssHref}
    />
    <title>{title}</title>
    {/*
     * Pages can inject extra <head> content (SEO meta tags, JSON-LD, etc.)
     * via this named slot. Keeping <SEOHead> inside <head> avoids the
     * "Charset declaration is missing or occurs too late" Lighthouse audit
     * that fires when SEOHead is rendered as top-level page markup.
     */}
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class="bg-bg text-fg font-sans">
    <a href="#main" class="skip-to-content">
      {t("a11y.skip_to_content", {}, lang)}
    </a>
    <div class="relative min-h-screen p-2 gap-2 flex items-stretch">
      <main id="main" class="rounded-lg bg-surface flex-1 mx-auto overflow-y-auto w-full">
        <slot />
      </main>
    </div>
    <div
      id="not-support"
      class="fixed hidden bg-danger bottom-0 inset-x-0 rounded-t-md text-center py-2 lg:py-4 z-50 font-semibold text-white"
    >
      It seems your browser does not support view transitions yet :( try it
      using chrome or edge
    </div>
    {showAnalytics && <Analytics />}
  </body>
</html>
