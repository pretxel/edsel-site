---
import type { Language } from "../lib/i18n";
import { defaultLanguage } from "../lib/i18n";

interface Props {
  title: string;
  image?: string | undefined;
  lang?: Language;
  rssHref?: string;
  rssTitle?: string;
}

const {
  title = "Home",
  lang = defaultLanguage,
  rssHref = "/rss.xml",
  rssTitle = "Edsel Serrano - Blog",
} = Astro.props;
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";
import "./layout.css";
import "../styles/blog.css";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={rssTitle}
      href={rssHref}
    />
    <title>{title}</title>
    <!-- Google Tag Manager -->
    <script defer>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({
          "gtm.start": new Date().getTime(),
          event: "gtm.js",
        });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-KW47SVK");
    </script>
    <!-- End Google Tag Manager -->
    <ClientRouter />
  </head>
  <body class="dark">
    <div class="relative h-screen p-2 gap-2 flex items-stretch">
      <div class="rounded-lg bg-zinc-900 flex-1 mx-auto overflow-y-auto">
        <slot />
      </div>
    </div>
    <div
      id="not-support"
      class="fixed hidden bg-red-700 bottom-0 inset-x-0 rounded-t-md text-center py-2 lg:py-4 z-50 font-semibold"
    >
      It seems your browser does not support view transitions yet :( try it
      using chrome or edge
    </div>
    <Analytics />
  </body>
</html>
