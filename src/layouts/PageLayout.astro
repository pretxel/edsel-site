---
import type { Language } from "../lib/i18n";
import {
  defaultLanguage,
  formatDateShort,
  t,
} from "../lib/i18n";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import Social from "../components/Social/index.astro";
import "./layout.css";
import "../styles/blog.css";

interface Props {
  /** Resolved page title shown in <title> and as the H1. */
  title: string;
  /** Eyebrow shown above the H1 (e.g. "About", "Now", "Uses"). */
  eyebrow?: string;
  /** Short summary used in the head; also passed through to SEOHead by the page. */
  description?: string;
  /** Last-updated date for the prose. Optional — hidden when absent. */
  updated?: Date;
  /** Active language for switcher + footer copy. */
  lang?: Language;
  /** Path used by the LanguageSwitcher to build the other-language URL. */
  currentPath?: string;
}

const {
  title,
  eyebrow,
  description,
  updated,
  lang = defaultLanguage,
  currentPath = "/",
} = Astro.props;

const homeHref = lang === "en" ? "/en/" : "/";
const updatedLabel = updated
  ? t(
      "page.last_updated",
      { date: formatDateShort(updated.toISOString(), lang) },
      lang,
    )
  : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    {/*
     * Preload the Latin Inter variable font. Same rationale as BlogLayout/
     * MainHead — discovered before CSS parses, saves ~300ms FCP on 4G.
     */}
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
      href="/_astro/inter-latin-wght-normal.Dx4kXJAl.woff2"
    />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <slot name="head" />
    <style>
      .page-social ul {
        display: flex;
        gap: 1rem;
        align-items: center;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .page-social a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 9999px;
        border: 1px solid var(--border-strong);
        color: var(--fg-default);
        transition: background-color var(--dur-base) var(--ease-out),
          color var(--dur-base) var(--ease-out);
      }
      .page-social a:hover {
        background: var(--bg-muted);
        color: var(--fg-strong);
      }
      .page-social a [data-icon] {
        width: 1rem;
        height: 1rem;
      }
      .page-social a span {
        display: none;
      }
    </style>
  </head>
  <body class="bg-bg text-fg font-sans min-h-screen">
    <a href="#main" class="skip-to-content">
      {t("a11y.skip_to_content", {}, lang)}
    </a>
    <div class="min-h-screen flex flex-col">
      <header
        class="sticky top-0 z-40 bg-surface/80 backdrop-blur-xl border-b border-border-default"
      >
        <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
          <a
            href={homeHref}
            class="inline-flex items-center text-sm font-medium text-fg-muted hover:text-fg-strong transition-colors"
          >
            <span>{t("page.back_home", {}, lang)}</span>
          </a>
          <LanguageSwitcher currentLanguage={lang} currentPath={currentPath} />
        </div>
      </header>

      <main id="main" class="flex-1 px-6 py-12 sm:py-16">
        <article class="max-w-prose mx-auto">
          <div class="mb-10">
            {eyebrow && (
              <p
                class="font-mono text-xs uppercase tracking-wide text-accent mb-3"
              >
                {eyebrow}
              </p>
            )}
            <h1
              class="text-4xl sm:text-5xl font-bold text-fg-strong leading-tight tracking-tight"
            >
              {title}
            </h1>
            {updatedLabel && (
              <p class="mt-3 font-mono text-xs text-fg-subtle">
                {updatedLabel}
              </p>
            )}
          </div>

          <div class="prose prose-invert max-w-none">
            <slot />
          </div>
        </article>
      </main>

      <footer
        class="border-t border-border-default px-6 py-10 mt-12 bg-surface/40"
      >
        <div class="max-w-3xl mx-auto flex flex-col items-center gap-4">
          <nav aria-label="More" class="text-sm">
            <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-fg-muted">
              <li>
                <a
                  href={lang === "en" ? "/en/uses" : "/uses"}
                  class="hover:text-accent transition-colors"
                  >{t("nav.uses", {}, lang)}</a
                >
              </li>
              <li>
                <a
                  href={lang === "en" ? "/en/now" : "/now"}
                  class="hover:text-accent transition-colors"
                  >{t("nav.now", {}, lang)}</a
                >
              </li>
              <li>
                <a
                  href={lang === "en" ? "/en/blog" : "/blog"}
                  class="hover:text-accent transition-colors"
                  >{t("nav.blog", {}, lang)}</a
                >
              </li>
            </ul>
          </nav>
          <div class="page-social text-fg-muted">
            <Social />
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
